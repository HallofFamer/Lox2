namespace test.features

class Street {

    val String name
    val Int apartment
    val Int unit

    __init__(String name, Int apartment, Int unit){ 
        this.name = name
        this.apartment = apartment
        this.unit = unit
    }
}

class Area { 

    val String city
    val String state
    val String country
    val Int zipcode

    __init__(String city, String state, String country, Int zipcode){ 
        this.city = city
        this.state = state
        this.country = country
        this.zipcode = zipcode
    }
}
 
class Address { 

    val Street street
    val Area area

    __init__(){ 
        this.street = nil
        this.area = nil
    }
}

val address = Address()
address.street = Street("Broadway", 1681, nil)
address.area = Area("New York", "ny", "United State", 10018)
val address2 = Address()
print("State for address: ")
println(address.area?.state?.toUppercase())
print("State for address 2: ")
println(address2.area?.state?.toUppercase())
print("Zipcode for address: ")
println(address.area?.zipcode ?? "00000")
print("Zipcode for address 2: ")
println(address2.area?.zipcode ?? "00000")