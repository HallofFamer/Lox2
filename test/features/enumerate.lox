namespace test.features

println("Iterating over Int 5: ")
5.timesRepeat({|i| print("${i }") })
println("\nIterating from Int 5 to 10: ")
5.upTo(10, {|i| print("${i} ") })
println("\n")

val array = [2, 3.5, true, "Hello World"]
println("Enumerating array with each method: ")
array.each({|element| println("Element: ${element}") })

val selected = array.select({|x| x.instanceOf(Number) })
println("\nSelecting elements that are numbers: ")
println(selected)

val rejected = array.reject({|x| x.instanceOf(Number) })
println("Rejecting elements that are numbers: ")
println(rejected)

val array2 = [1, 2, 3, 4, 5]
println("\nEnumerating a number array with index: ")
array2.eachIndex({|index, element| println("Element ${index}: ${element}") })

println("\nCollect a number array by square: ")
println(array2.collect({|x| x * x }))
println("Detecting first even number: ")
println(array2.detect({|x| x.isEven() }))

val dict = ["US": "United States", "CA": "Canada", "EU": "Europe", "JP": "Japan", "RU": "Russia"]
println("\nEnumerating a dictionary of countries: ")
dict.each({|key, value| println("Key: ${key}, Value: ${value}") })
println("Select countries with length 6: ")
val dict2 = dict.select({|key, value| value.length() == 6 })
println(dict2)