namespace test.std
using clox.std.collection.Set
using clox.std.util.Date

val set = Set()
println("Testing class Set...")
println("Class for set object: ${set.getClassName()}")
println("Set is currently empty: ${set.isEmpty()}\n")

println("Now adding elements to set...")
set.add(2)
set.add(3.5)
set.add(true)
set.add(false)
set.add(Date.now)
println("Initial elements in set: ${set.toString()}")
println("Add a new element current 'Hello World' to set: ")
set.add("Hello World")
println("Current elements in set: ${set.toString()}")
println("Now add a duplicate element 2 to the set: ")
set.add(2)
println("Current elements in set: ${set.toString()}")
set.remove(3.5)
println("Remove an element 3.5 from Set: ${set.toString()}")

println("Looping through elements in set...")
for(val element : set){
    println("Element: ${element}")
}

val set2 = Set()
set2.add(1)
set2.add(2)
set2.add(3)
set2.add(4)
println("\nSet 2 elements: ${set2.toString()}")

val set3 = Set()
set3.add(3)
set3.add(4)
set3.add(5)
set3.add(6)
println("Set 3 elements: ${set3.toString()}")

val set4 = set2.union(set3)
println("Union of set 2 and set 3: ${set4.toString()}")
val set5 = set2.intersection(set3)
println("Intersection of set 2 and set 3: ${set5.toString()}")
val set6 = set2.difference(set3)
println("Difference of set 2 and set 3: ${set6.toString()}")