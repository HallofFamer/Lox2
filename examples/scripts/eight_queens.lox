namespace examples.scripts
using examples.lib.EightQueens

val eightQueens = EightQueens(8)
val solutions = eightQueens.solve()

println("Number of solutions for 8 queens: ${solutions.length}")
println("Solutions for 8 queens:")
for (val (i, solution) : solutions) {
    println("Solution: ${i + 1}")
	println(solution)
	println("\n")
}